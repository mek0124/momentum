{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git Update",
      "type": "shell",
      "command": "git fetch origin && git pull origin main",
      "windows": {
        "command": "git fetch origin && git pull origin main"
      },
      "linux": {
        "command": "git fetch origin && git pull origin main"
      },
      "osx": {
        "command": "git fetch origin && git pull origin main"
      },
      "problemMatcher": [],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "detail": "Fetches and pulls from origin/main branch"
    }
  ]
}
